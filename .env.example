# =============================================================================
# ExpressiveAI.online — Environment Variables Reference
# =============================================================================
# Copy each section into the corresponding app's env file:
#   apps/api/.env
#   apps/worker/.env
#   apps/web/.env.local
# Never commit real secrets to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE  (shared across api + worker + web)
# Dashboard → https://supabase.com/dashboard/project/<id>/settings/api
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-keep-secret>        # api + worker only
SUPABASE_ANON_KEY=<anon-public-key>                             # web only
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co      # web only
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>                 # web only


# -----------------------------------------------------------------------------
# CLERK  (authentication)
# Dashboard → https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<key>                 # web only
CLERK_SECRET_KEY=sk_test_<key>                                  # api + web
CLERK_WEBHOOK_SECRET=whsec_<key>                                # api only — from Clerk Dashboard → Webhooks

# Clerk redirect URLs (Next.js)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard


# -----------------------------------------------------------------------------
# STRIPE  (payments)
# Dashboard → https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_<key>                                 # api only
STRIPE_WEBHOOK_SECRET=whsec_<key>                               # api only — from Stripe CLI / Dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<key>                # web only

# Stripe price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_<id>         # Starter plan
STRIPE_PRICE_PRO=price_<id>             # Pro plan
STRIPE_PRICE_CREATOR=price_<id>         # Creator plan
STRIPE_PRICE_ENTERPRISE=price_<id>      # Enterprise plan


# -----------------------------------------------------------------------------
# REDIS / UPSTASH  (BullMQ job queue)
# Dashboard → https://console.upstash.com
# Use rediss:// (TLS) for Upstash; redis:// for local
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379


# -----------------------------------------------------------------------------
# HUGGING FACE  (AI video generation inference)
# Dashboard → https://huggingface.co/settings/tokens
# -----------------------------------------------------------------------------
HUGGINGFACE_API_KEY=hf_<key>
# Model endpoint — override if using a custom/fine-tuned model
HUGGINGFACE_MODEL_ID=stabilityai/stable-video-diffusion-img2vid-xt


# -----------------------------------------------------------------------------
# STORAGE  (video / thumbnail assets)
# Supabase Storage bucket name or S3-compatible bucket
# -----------------------------------------------------------------------------
STORAGE_BUCKET=expressiveai-videos
# Optional: custom CDN prefix if using Cloudflare R2 / S3
STORAGE_CDN_URL=https://cdn.expressiveai.online


# -----------------------------------------------------------------------------
# API SERVER
# -----------------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:3000           # set to https://expressiveai.online in prod
NODE_ENV=development                          # development | production


# -----------------------------------------------------------------------------
# WEB / NEXT.JS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001     # set to https://api.expressiveai.online in prod
NEXT_PUBLIC_APP_URL=http://localhost:3000     # set to https://expressiveai.online in prod


# -----------------------------------------------------------------------------
# EMAIL  (transactional — optional, nodemailer)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_<key>
EMAIL_FROM=noreply@expressiveai.online
